{
  "type": "object",
  "properties": {
    "booking_id": {
      "type": "string",
      "description": "LiteAPI booking reference ID"
    },
    "hotel_id": {
      "type": "string",
      "description": "LiteAPI hotel ID"
    },
    "hotel_name": {
      "type": "string",
      "description": "Name of the hotel"
    },
    "guest_first_name": {
      "type": "string"
    },
    "guest_last_name": {
      "type": "string"
    },
    "guest_email": {
      "type": "string"
    },
    "checkin": {
      "type": "string",
      "description": "Check-in date (YYYY-MM-DD)"
    },
    "checkout": {
      "type": "string",
      "description": "Check-out date (YYYY-MM-DD)"
    },
    "nights": {
      "type": "number"
    },
    "adults": {
      "type": "number"
    },
    "room_name": {
      "type": "string"
    },
    "total_price": {
      "type": "number",
      "description": "Total price charged to guest (USD)"
    },
    "margin_percent": {
      "type": "number",
      "description": "Commission margin applied (%)"
    },
    "commission_earned": {
      "type": "number",
      "description": "Estimated commission in USD"
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "cancelled",
        "completed"
      ],
      "default": "confirmed"
    },
    "payout_status": {
      "type": "string",
      "enum": [
        "pending",
        "paid"
      ],
      "default": "pending"
    },
    "destination": {
      "type": "string"
    }
  },
  "required": [],
  "name": "Booking"
}